# ═══════════════════════════════════════════════════════════
#  Cloudonomix — Environment Variables
#  Copy this file to .env and fill in all values
#  NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars
DATABASE_URL=sqlite:///cloudonomix.db
FLASK_ENV=development
JWT_EXPIRY_HOURS=24

# ── Admin ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@cloudonomix.io
ADMIN_PASSWORD=your_strong_admin_password_here

# ── REQUIRED: Credential Encryption ───────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If not set, credentials stored with weak fallback key
# On Render.com, use generateValue: true in render.yaml (auto-set)
ENCRYPTION_KEY=generate-using-command-above

# ── Gmail SMTP ─────────────────────────────────────────────
# Step 1: Enable 2FA on your Gmail account
# Step 2: myaccount.google.com → Security → App passwords
# Step 3: Select Mail + Other (type "Cloudonomix") → copy 16-char password
MAIL_EMAIL=your_gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── App URL (for email links) ──────────────────────────────
# Development:
APP_URL=http://localhost:3000
# Production (update after deployment):
# APP_URL=https://cloudonomix.in

# ── WhatsApp (for upgrade prompts) ────────────────────────
# Your mobile number with country code, no + or spaces
# Example: 919845012345 (91 = India code, then 10-digit mobile)
WHATSAPP_NUMBER=919XXXXXXXXX

# ── Cron Job Security ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Use same value in Render cron job environment
CRON_SECRET=generate-using-command-above

# ── CORS (Security) ────────────────────────────────────────
# Restrict API to specific domains — separate multiple with comma
# Development: leave as * to allow localhost
# Production:  https://cloudonomix.in,https://www.cloudonomix.in
ALLOWED_ORIGINS=*

# ── Razorpay (Optional — for auto-billing) ─────────────────
# Sign up at razorpay.com → Settings → API Keys
# Leave blank to use manual WhatsApp payment flow
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
